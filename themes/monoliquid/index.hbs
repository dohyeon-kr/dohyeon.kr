{{!< default}}

<main id="main-content" class="site-main">
    {{#if @site.members_enabled}}
        <section class="newsletter-band">
            <div>
                <p class="eyebrow eyebrow--inverse">Subscribe</p>
                <h2>새 글을 조용히 받아보기</h2>
                <p>제품, 코드, 의사결정에 관한 긴 글을 보냅니다.</p>
            </div>
            <a class="button button--inverse" href="#/portal/signup">Subscribe</a>
        </section>
    {{/if}}

    <section id="posts" class="post-index">
        <div class="section-heading">
            <p class="eyebrow">Latest</p>
            <h2>최근 글</h2>
        </div>

        <div class="post-grid">
            {{#foreach posts}}
                {{> "post-card"}}
            {{/foreach}}
        </div>
    </section>

    {{pagination}}
</main>
