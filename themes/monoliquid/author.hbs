{{!< default}}

<main id="main-content" class="site-main">
    <section class="archive-header">
        {{#author}}
            <p class="eyebrow">Author archive</p>
            <h1>{{name}}</h1>
            {{#if bio}}
                <p>{{bio}}</p>
            {{/if}}
        {{/author}}
    </section>

    <div class="post-grid wrapper--ticks">
        {{#foreach posts}}
            {{> "post-card"}}
        {{/foreach}}
    </div>

    {{pagination}}
</main>
