---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import type { CollectionEntry } from "astro:content";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import BlogCategories from "../components/BlogCategories.astro";

type Props = {
    posts: CollectionEntry<"blog">[];
};

const { posts } = Astro.props;

const filteredPosts = posts.filter((post) => !post.data.WIP);
const renderReadyPosts = filteredPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            main {
                max-width: 1280px;
                width: 100%;
            }
            h6 {
                font-weight: bold;
            }
        </style>
    </head>
    <body>
        <Header />
        <main class="grid gap-5">
            <section>
                <h6>Categories</h6>
                <div
                    class="text-base **:[a]:text-gray-500! **:[a]:hover:text-gray-700!"
                >
                    <BlogCategories posts={renderReadyPosts} />
                </div>
            </section>
            <section>
                <h6>Posts</h6>
                <ul
                    class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-4"
                >
                    {
                        renderReadyPosts.map((post) => (
                            <li class="border-b border-gray-300 py-5 space-y-3">
                                <a
                                    href={`/blog/post/${post.id}/`}
                                    class="block"
                                >
                                    {post.data.heroImage ? (
                                        <Image
                                            width={720}
                                            height={360}
                                            src={post.data.heroImage}
                                            alt=""
                                        />
                                    ) : (
                                        <img
                                            src={`/og/${post.id}.png`}
                                            alt=""
                                            width={720}
                                            height={360}
                                        />
                                    )}
                                </a>
                                <a
                                    href={`/blog/c/${post.data.category}/`}
                                    class="hover:text-gray-700 text-gray-500! text-sm block"
                                >
                                    {post.data.category}
                                </a>
                                <a href={`/blog/post/${post.id}/`}>
                                    <h4 class="title">{post.data.title}</h4>
                                    <p class="date text-sm mb-0! text-gray-700">
                                        <FormattedDate
                                            date={post.data.pubDate}
                                        />
                                    </p>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>
        </main>
        <Footer />
    </body>
</html>
